# Terraform state files — never commit these
*.tfstate
*.tfstate.*
*.tfstate.backup

# Crash log files
crash.log
crash.*.log

# Terraform variable files that may contain secrets
*.tfvars
*.tfvars.json
!*.example.tfvars

# Terraform lock file — commit this to pin provider versions
# .terraform.lock.hcl  (intentionally NOT ignored)

# Terraform working directories
**/.terraform/
**/.terraform.lock.hcl.bak

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# CLI config file
.terraformrc
terraform.rc

# SSH keys and certificates
*.pem
*.key
*.crt
*.p12

# Environment variable files
.env
.env.*
!.env.example

# macOS
.DS_Store

# Editor directories and files
.idea/
.vscode/
*.swp
*.swo
